@dp.message(Command("setrank"))
async def cmd_setrank_start(message: types.Message, state: FSMContext):
    """Начало установки должности"""
    if message.from_user.id != MAIN_ADMIN_ID:
        await message.answer("❌ У вас нет прав администратора!")
        return
    
    await message.answer(
        "⚙️ **Установка должности**\n\n"
        "Введите ID пользователя:",
        parse_mode="Markdown"
    )
    await state.set_state(SetRankStates.waiting_for_user_id)

@dp.message(SetRankStates.waiting_for_user_id)
async def setrank_user_id(message: types.Message, state: FSMContext):
    """Получение ID пользователя"""
    try:
        user_id = int(message.text)
        if user_id not in users_db:
            await message.answer("❌ Пользователь не найден!")
            await state.clear()
            return
        
        await state.update_data(target_user_id=user_id)
        
        # Создаем клавиатуру с должностями
        builder = InlineKeyboardBuilder()
        for rank in Rank:
            builder.add(InlineKeyboardButton(
                text=rank.value,
                callback_data=f"setrank_{rank.name}"
            ))
        builder.adjust(1)
        
        await message.answer(
            "Выберите должность:",
            reply_markup=builder.as_markup()
        )
        await state.set_state(SetRankStates.waiting_for_rank)
    except ValueError:
        await message.answer("❌ Введите корректный ID!")

@dp.callback_query(SetRankStates.waiting_for_rank, F.data.startswith("setrank_"))
async def setrank_choose(callback: CallbackQuery, state: FSMContext):
    """Выбор должности"""
    rank_name = callback.data.replace("setrank_", "")
    rank = Rank[rank_name]
    
    user_data = await state.get_data()
    target_user_id = user_data.get("target_user_id")
    
    users_db[target_user_id]["rank"] = rank
    users_db[target_user_id]["added_by"] = callback.from_user.first_name
    
    await callback.message.edit_text(
        f"✅ Должность установлена!\n"
        f"Пользователь: {users_db[target_user_id].get('nickname', 'Неизвестно')}\n"
        f"Должность: {rank.value}"
    )
    
    # Уведомляем пользователя
    try:
        await bot.send_message(
            target_user_id,
            f"✅ **Вам установлена должность:**\n"
            f"**{rank.value}**",
            parse_mode="Markdown"
        )
    except:
        pass
    
    await state.clear()
    await callback.answer()

