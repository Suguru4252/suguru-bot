# Вспомогательные функции
def format_user_stats(user_id: int) -> str:
    """Форматирует статистику пользователя"""
    user = users_db.get(user_id)
    if not user:
        return "Пользователь не найден"
    
    # Расчет дней на должности
    days_on_position = 0
    if "registration_date" in user:
        days_on_position = (datetime.now() - user["registration_date"]).days
    
    # Получение норматива
    rank = user.get("rank", Rank.JUNIOR_MODER)
    norm = RANK_NORMS.get(rank, {"online": 0, "answers": 0})
    
    # Формирование статистики
    stats = f"""
╔══════════════════════════╗
║     📊 **ВАША СТАТИСТИКА**     ║
╚══════════════════════════╝

👤 **Никнейм:** {user.get('nickname', 'Не указан')}
📋 **Должность:** {rank.value}
👥 **Добавил:** {user.get('added_by', 'Система')}
📅 **Дата назначения:** {user.get('registration_date', datetime.now()).strftime('%d.%m.%Y')}
⏳ **Дней на должности:** {days_on_position}
📈 **Норматив:** {norm['online']} онлайн / {norm['answers']} ответов
🎂 **Возраст:** {user.get('age', 'Не указан')}
🌍 **Часовой пояс:** {user.get('timezone', 'Не указан')}
💻 **Доступ к ПК:** {user.get('pc_access', 'Не указан')}

🔗 **Ссылки:**
• ВКонтакте: {user.get('vk', 'Не указано')}
• Telegram: {user.get('tg', 'Не указано')}
• Форум: {user.get('forum', 'Не указано')}
• Discord: {user.get('discord', 'Не указано')}

📊 **Успеваемость:**
• Онлайн: {user.get('online', 0)}
• Ответы: {user.get('answers', 0)}
• Баллы: {user.get('points', 0)}

⚠️ **Наказания:**
• Выговоры: {user.get('reprisals', 0)}
"""
    return stats

def check_norm_compliance(photo_text: str, rank: Rank) -> tuple:
    """Проверяет соответствие норме по тексту из фото"""
    try:
        # Извлекаем числа из текста
        online_match = re.search(r'Онлайн[:\s]*(\d+)', photo_text, re.IGNORECASE)
        answers_match = re.search(r'Ответы[:\s]*(\d+)', photo_text, re.IGNORECASE)
        
        if not online_match or not answers_match:
            return False, "Не удалось распознать данные на фото"
        
        online = int(online_match.group(1))
        answers = int(answers_match.group(1))
        
        norm = RANK_NORMS.get(rank, {"online": 0, "answers": 0})
        
        if online >= norm['online'] and answers >= norm['answers']:
            return True, f"✅ Норма сдана!\nОнлайн: {online}/{norm['online']}\nОтветы: {answers}/{norm['answers']}"
        else:
            return False, f"❌ Норма не сдана\nОнлайн: {online}/{norm['online']}\nОтветы: {answers}/{norm['answers']}"
    except Exception as e:
        return False, f"Ошибка при проверке: {str(e)}"

