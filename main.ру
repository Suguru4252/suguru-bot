            days_on_position = 0
    
    rank_value = user.get('rank', Rank.JUNIOR_MODER.value)
    rank = next((r for r in Rank if r.value == rank_value), Rank.JUNIOR_MODER)
    norm = RANK_NORMS.get(rank, {"online": 0, "answers": 0})
    
