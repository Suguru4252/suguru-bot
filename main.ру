# Функции проверки прав
def is_bot_admin(user_id: int) -> bool:
    """Проверяет, является ли пользователь администратором бота"""
    return user_id in bot_admins

def get_admin_level(user_id: int) -> int:
    """Возвращает уровень администратора"""
    if user_id == MAIN_ADMIN_ID:
        return BotAdminLevel.SUPER_ADMIN.value
    return bot_admins.get(user_id, 0)

def can_moderate_apps(user_id: int) -> bool:
    """Может ли просматривать заявки (нормы, доп баллы, неактив)"""
    level = get_admin_level(user_id)
    return level >= BotAdminLevel.MODER_ADMIN.value

def can_manage_users(user_id: int) -> bool:
    """Может ли управлять пользователями"""
    level = get_admin_level(user_id)
    return level >= BotAdminLevel.FULL_ADMIN.value

def is_super_admin(user_id: int) -> bool:
    """Является ли главным администратором"""
    return user_id == MAIN_ADMIN_ID or get_admin_level(user_id) >= BotAdminLevel.SUPER_ADMIN.value

def is_blocked(user_id: int) -> bool:
    """Проверяет, заблокирован ли пользователь"""
    return user_id in blocked_users

# Декоратор для проверки доступа
def check_access(func):
    """Декоратор для проверки доступа к боту"""
    async def wrapper(message: types.Message, *args, **kwargs):
        user_id = message.from_user.id
        
        # Проверка на блокировку
        if is_blocked(user_id):
            await message.answer("⛔ **Доступ запрещен!**\n\nВы были заблокированы администрацией.", parse_mode="Markdown")
            return
        
        # Если пользователь не зарегистрирован - пропускаем только /start
        if user_id not in users_db and message.text != "/start":
            await message.answer("❌ Сначала зарегистрируйтесь через /start")
            return
        
        return await func(message, *args, **kwargs)
    return wrapper

