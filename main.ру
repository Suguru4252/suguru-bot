# Функции проверки ВК
def check_vk_profile(vk_input: str) -> tuple:
    """
    Проверяет существование профиля ВК
    Возвращает (True, сообщение) если профиль существует
    """
    # Очищаем входные данные
    vk_input = vk_input.strip()
    
    # Извлекаем ID или короткое имя
    if 'vk.com/' in vk_input:
        screen_name = vk_input.split('vk.com/')[-1].split('/')[0].split('?')[0]
    elif 'vkontakte.ru/' in vk_input:
        screen_name = vk_input.split('vkontakte.ru/')[-1].split('/')[0].split('?')[0]
    elif vk_input.isdigit():
        screen_name = vk_input
    else:
        screen_name = vk_input
    
    try:
        # Пытаемся получить информацию о профиле
        response = requests.get(
            f"https://api.vk.com/method/users.get",
            params={
                "user_ids": screen_name,
                "access_token": "ваш_токен",  # Можно получить в VK Dev
                "v": "5.131"
            },
            timeout=5
        )
        
        data = response.json()
        
        if 'response' in data and len(data['response']) > 0:
            user = data['response'][0]
            full_name = f"{user.get('first_name', '')} {user.get('last_name', '')}".strip()
            return True, f"✅ Профиль найден: {full_name}"
        else:
            return False, "❌ Профиль не найден"
            
    except Exception as e:
        # Если API не работает, проверяем хотя бы формат
        if re.match(r'^[a-zA-Z0-9_.]+$', screen_name) and len(screen_name) > 2:
            return True, "✅ Формат ссылки корректный"
        else:
            return False, "❌ Неверный формат ссылки ВК"

# Функции валидации
def validate_timezone_msk(tz: str) -> bool:
    """Проверяет часовой пояс в формате МСК, МСК+1, МСК-4 и т.д."""
    tz = tz.upper().replace(' ', '')
    pattern = r'^МСК([+-][0-9]{1,2})?$'
    return bool(re.match(pattern, tz))

def validate_vk_link_simple(vk_input: str) -> bool:
    """Простая проверка ссылки ВК"""
    vk_input = vk_input.strip()
    
    # Проверяем разные форматы
    patterns = [
        r'^https?://vk\.com/[a-zA-Z0-9_.]+$',
        r'^https?://vkontakte\.ru/[a-zA-Z0-9_.]+$',
        r'^vk\.com/[a-zA-Z0-9_.]+$',
        r'^[a-zA-Z0-9_.]+$',  # Только ID
        r'^id[0-9]+$'  # id123456
    ]
    
    for pattern in patterns:
        if re.match(pattern, vk_input, re.IGNORECASE):
            return True
    return False

def validate_telegram_username(username: str) -> bool:
    username = username.replace('@', '').strip()
    pattern = r'^[a-zA-Z][a-zA-Z0-9_]{4,}$'
    return bool(re.match(pattern, username))

def validate_forum_link(link: str) -> bool:
    # Для Black Russia форум
    patterns = [
        r'^https?://forum\.blackrussia\.ru/.*$',
        r'^https?://blackrussia\.forum/.*$',
        r'^[a-zA-Z0-9_.]+$'
    ]
    return any(re.match(pattern, link, re.IGNORECASE) for pattern in patterns)

def validate_discord_username(username: str) -> bool:
    pattern = r'^[a-zA-Z0-9_]{3,32}(#[0-9]{4})?$'
    return bool(re.match(pattern, username.strip()))

def validate_age(age: str) -> bool:
    try:
        age_num = int(age)
        return 10 <= age_num <= 100
    except ValueError:
        return False

def validate_pc_access(access: str) -> bool:
    return access.lower() in ['да', 'нет', 'yes', 'no', 'есть', 'нету']

