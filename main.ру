            cursor.execute("SELECT user_id FROM users WHERE discord_username = ?", (discord,))
            return cursor.fetchone() is not None
    
    # ===== РАБОТА С ПОЛЬЗОВАТЕЛЯМИ =====
    def add_user(self, user_data: dict) -> bool:
        try:
            with self.get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute('''
                    INSERT INTO users (
                        user_id, nickname, telegram_username, age, timezone, 
                        pc_access, vk_link, forum_link, discord_username, rank, added_by
                    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                ''', (
                    user_data['user_id'],
                    user_data['nickname'],
                    user_data['tg_username'],
                    user_data['age'],
                    user_data['timezone'],
                    user_data['pc_access'],
                    user_data['vk'],
                    user_data['forum'],
                    user_data['discord'],
                    user_data.get('rank', Rank.JUNIOR_MODER.value),
                    user_data.get('added_by', 'Система')
                ))
                conn.commit()
                return True
        except sqlite3.IntegrityError as e:
            logger.error(f"Ошибка уникальности при добавлении пользователя: {e}")
            return False
    
    def get_user(self, user_id: int) -> Optional[dict]:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM users WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            if row:
                return dict(row)
            return None
    
    def update_user(self, user_id: int, **kwargs) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            set_clause = ", ".join([f"{key} = ?" for key in kwargs.keys()])
            values = list(kwargs.values()) + [user_id]
            cursor.execute(f"UPDATE users SET {set_clause} WHERE user_id = ?", values)
            conn.commit()
            return cursor.rowcount > 0
    
    def block_user(self, user_id: int) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("UPDATE users SET is_blocked = 1 WHERE user_id = ?", (user_id,))
            conn.commit()
            return cursor.rowcount > 0
    
    def unblock_user(self, user_id: int) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("UPDATE users SET is_blocked = 0 WHERE user_id = ?", (user_id,))
            conn.commit()
            return cursor.rowcount > 0
    
    def is_user_blocked(self, user_id: int) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT is_blocked FROM users WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            return row and row['is_blocked'] == 1
    
    # ===== РАБОТА С АДМИНАМИ =====
    def add_bot_admin(self, user_id: int, added_by: int, level: int = 50) -> bool:
        try:
            with self.get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute('''
                    INSERT INTO bot_admins (user_id, admin_level, added_by)
                    VALUES (?, ?, ?)
                ''', (user_id, level, added_by))
                conn.commit()
                return True
        except sqlite3.IntegrityError:
            return False
    
    def remove_bot_admin(self, user_id: int) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("DELETE FROM bot_admins WHERE user_id = ?", (user_id,))
            conn.commit()
            return cursor.rowcount > 0
    
    def is_bot_admin(self, user_id: int) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM bot_admins WHERE user_id = ?", (user_id,))
            return cursor.fetchone() is not None
    
    def get_admin_level(self, user_id: int) -> int:
        if user_id == MAIN_ADMIN_ID:
            return 999
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT admin_level FROM bot_admins WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            return row['admin_level'] if row else 0
    
    def get_all_admins(self) -> List[dict]:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute('''
                SELECT u.*, ba.admin_level 
                FROM users u 
                JOIN bot_admins ba ON u.user_id = ba.user_id
            ''')
            return [dict(row) for row in cursor.fetchall()]
    
    # ===== РАБОТА С ЗАЯВКАМИ =====
    def save_application(self, app_data: dict) -> bool:
        try:
            with self.get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute('''
                    INSERT INTO applications (app_id, user_id, app_type, description, file_id)
                    VALUES (?, ?, ?, ?, ?)
                ''', (
                    app_data['app_id'],
                    app_data['user_id'],
                    app_data['app_type'],
                    app_data.get('description', ''),
                    app_data.get('file_id', '')
                ))
                conn.commit()
                return True
        except Exception as e:
            logger.error(f"Ошибка при сохранении заявки: {e}")
            return False
    
    def update_application_status(self, app_id: str, status: str) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("UPDATE applications SET status = ? WHERE app_id = ?", (status, app_id))
            conn.commit()
            return cursor.rowcount > 0

