@dp.callback_query(F.data.startswith("approve_"))
async def approve_application(callback: CallbackQuery, state: FSMContext):
    if not is_bot_admin(callback.from_user.id):
        await callback.answer("❌ Нет прав!")
        return
    
    # Сбрасываем состояние
    await state.clear()
    
    _, app_type, app_id = callback.data.split("_", 2)
    
    pending_dict = {
        "norm": pending_norms,
        "promotion": pending_promotions,
        "extra": pending_extra_works,
        "inactive": pending_inactives,
        "reprisal": pending_reprisals
    }.get(app_type)
    
    if not pending_dict or app_id not in pending_dict:
        await callback.message.edit_text("❌ Заявка не найдена или уже обработана")
        await callback.answer()
        return
    
    app_data = pending_dict[app_id]
    user_id = app_data['user_id']
    
    # Обновляем статус в базе данных
    db.update_application_status(app_id, "approved")
    
    # Начисляем баллы в зависимости от типа заявки
    if app_type == "norm":
        user = db.get_user(user_id)
        if user:
            db.update_user(user_id, 
                          points=user.get('points', 0) + 20,
                          online=user.get('online', 0) + 50,
                          answers=user.get('answers', 0) + 50)
        await bot.send_message(user_id, "✅ Ваша норма одобрена!\n➕ Начислено 20 баллов")
    
    elif app_type == "promotion":
        user = db.get_user(user_id)
        if user:
            db.update_user(user_id, points=user.get('points', 0) + 30)
        await bot.send_message(user_id, "✅ Ваше повышение одобрено!\n➕ Начислено 30 баллов")
    
    elif app_type == "extra":
        user = db.get_user(user_id)
        if user:
            db.update_user(user_id, points=user.get('points', 0) + 15)
        await bot.send_message(user_id, "✅ Ваши доп баллы одобрены!\n➕ Начислено 15 баллов")
    
    elif app_type == "inactive":
        end_date = datetime.now() + timedelta(days=app_data['days'])
        await bot.send_message(
            user_id, 
            f"✅ Ваш неактив одобрен!\n⏳ Дней: {app_data['days']}\n📅 До: {end_date.strftime('%d.%m.%Y')}"
        )
    
    elif app_type == "reprisal":
        user = db.get_user(user_id)
        if user:
            current_warns = user.get('reprisals', 0)
            if current_warns > 0:
                db.update_user(user_id, reprisals=current_warns - 1)
            db.update_user(user_id, points=user.get('points', 0) + 10)
        await bot.send_message(
            user_id,
            f"✅ Ваш выговор снят!\n➕ Начислено 10 баллов"
        )
    
    # Удаляем из словаря
    del pending_dict[app_id]
    
    original_text = callback.message.caption if callback.message.caption else callback.message.text
    await callback.message.edit_text(
        f"✅ Заявка принята!\n\n{original_text}"
    )
    await callback.answer("✅ Принято!")

