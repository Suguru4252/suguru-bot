        await message.answer("❌ Неверный формат возраста. Введите число от 10 до 100:")
        return
    
    await state.update_data(age=int(message.text))
    await message.answer(
        "🌍 Введите ваш часовой пояс\n\n"
        "Формат: МСК, МСК+1, МСК-4 и т.д.\n"
