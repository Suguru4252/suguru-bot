# ==================== БАЗА ДАННЫХ ====================
class Database:
    def __init__(self, db_name: str = "bot_database.db"):
        self.db_name = db_name
        self.init_db()
    
    @contextmanager
    def get_connection(self):
        conn = sqlite3.connect(self.db_name)
        conn.row_factory = sqlite3.Row
        try:
            yield conn
        finally:
            conn.close()
    
    def init_db(self):
        """Инициализация таблиц в базе данных"""
        with self.get_connection() as conn:
            cursor = conn.cursor()
            
            # Таблица пользователей
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    user_id INTEGER PRIMARY KEY,
                    nickname TEXT UNIQUE NOT NULL,
                    telegram_username TEXT UNIQUE NOT NULL,
                    vk_link TEXT UNIQUE,
                    forum_link TEXT UNIQUE,
                    discord_username TEXT UNIQUE,
                    age INTEGER,
                    timezone TEXT,
                    pc_access TEXT,
                    rank TEXT DEFAULT 'Младший модератор',
                    added_by TEXT DEFAULT 'Система',
                    online INTEGER DEFAULT 0,
                    answers INTEGER DEFAULT 0,
                    points INTEGER DEFAULT 0,
                    reprisals INTEGER DEFAULT 0,
                    registration_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    is_blocked INTEGER DEFAULT 0
                )
            ''')
            
            # Таблица администраторов бота
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS bot_admins (
                    user_id INTEGER PRIMARY KEY,
                    admin_level INTEGER DEFAULT 50,
                    added_by INTEGER,
                    added_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    FOREIGN KEY (user_id) REFERENCES users(user_id)
                )
            ''')
            
            # Таблица для хранения заявок
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS applications (
                    app_id TEXT PRIMARY KEY,
                    user_id INTEGER,
                    app_type TEXT,
                    description TEXT,
                    file_id TEXT,
                    status TEXT DEFAULT 'pending',
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    FOREIGN KEY (user_id) REFERENCES users(user_id)
                )
            ''')
            
            # Добавляем главного администратора, если его нет
            cursor.execute("SELECT * FROM users WHERE user_id = ?", (MAIN_ADMIN_ID,))
            if not cursor.fetchone():
                cursor.execute('''
                    INSERT INTO users (user_id, nickname, telegram_username, age, timezone, pc_access, vk_link, forum_link, discord_username, rank)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                ''', (MAIN_ADMIN_ID, "Главный администратор", "admin", 18, "МСК", "Да", "vk.com/admin", "forum.ru/admin", "admin#0000", Rank.SENIOR_ADMIN.value))
                
                cursor.execute('''
                    INSERT INTO bot_admins (user_id, admin_level, added_by)
                    VALUES (?, ?, ?)
                ''', (MAIN_ADMIN_ID, 999, MAIN_ADMIN_ID))
            
            conn.commit()
    
    # ===== ПРОВЕРКИ НА УНИКАЛЬНОСТЬ =====
    def check_nickname_exists(self, nickname: str) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT user_id FROM users WHERE nickname = ?", (nickname,))
            return cursor.fetchone() is not None
    
    def check_telegram_username_exists(self, username: str) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT user_id FROM users WHERE telegram_username = ?", (username,))
            return cursor.fetchone() is not None
    
    def check_vk_link_exists(self, vk_link: str) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT user_id FROM users WHERE vk_link = ?", (vk_link,))
            return cursor.fetchone() is not None
    
    def check_forum_link_exists(self, forum_link: str) -> bool:
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT user_id FROM users WHERE forum_link = ?", (forum_link,))
            return cursor.fetchone() is not None
    
    def check_discord_username_exists(self, discord: str) -> bool:
        with self.get_connection() as conn:
