@dp.message(RegistrationStates.waiting_for_nickname)
async def reg_nickname(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    
    if len(message.text) < 3 or len(message.text) > 30:
        await message.answer("❌ Никнейм должен быть от 3 до 30 символов. Попробуйте еще раз:")
        return
    
    if db.check_nickname_exists(message.text):
        await message.answer("❌ Этот никнейм уже занят другим пользователем! Введите другой никнейм:")
        return
    
    await state.update_data(nickname=message.text)
    await message.answer("📅 Введите ваш возраст (от 10 до 100):")
    await state.set_state(RegistrationStates.waiting_for_age)

