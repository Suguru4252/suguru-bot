@dp.callback_query(F.data.startswith("app_"))
async def callback_app_handler(callback: CallbackQuery, state: FSMContext):
    user_id = callback.from_user.id
    app_type = callback.data.replace("app_", "")
    
    if is_blocked(user_id):
        await callback.answer("⛔ Доступ запрещен")
        return
    
    messages = {
        "norm": "📸 **Сдача норматива**\n\nПришлите фото с показателями Онлайн и Ответы.",
        "extra": "➕ **Дополнительные баллы**\n\nОпишите выполненную работу:",
        "inactive": "💤 **Заявка на неактив**\n\nНапишите причину неактива:",
        "promotion": "⬆️ **Заявка на повышение**\n\nКакая у вас сейчас должность?",
        "reprisal": "✅ **Снятие выговора**\n\nОтправьте выполненную работу:"
    }
    
    states = {
        "norm": ApplicationStates.norm_photo,
        "extra": ApplicationStates.extra_work_desc,
        "inactive": ApplicationStates.inactive_reason,
        "promotion": ApplicationStates.promotion_current_rank,
        "reprisal": ApplicationStates.reprisal_work
    }
    
    if app_type in messages:
        await callback.message.edit_text(messages[app_type], parse_mode="Markdown")
        await state.set_state(states[app_type])
    
    await callback.answer()

